body {
  background: linear-gradient(to bottom, #a678d8, #d8b7ff); /* بنفسجي فاتح بلمعة */
  font-family: Tahoma, Arial, sans-serif;
  text-align: center;
  direction: rtl;
  margin: 0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

h1 {
  margin-top: 20px;
  font-size: clamp(20px, 4vw, 36px); /* متجاوب */
  color: #fff;
  font-weight: bold;
}

#startBtn {
  background: #c2185b;
  color: #fff;
  font-size: clamp(18px, 3vw, 26px); /* متجاوب */
  padding: clamp(12px, 3vw, 20px);
  border: none;
  cursor: pointer;
  border-radius: 8px;
  margin: 40px auto 60px auto;
  font-weight: bold;
}

.modelBtn {
  background: #4caf50;
  color: #fff;
  padding: clamp(10px, 2.5vw, 18px);
  margin: 10px auto;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: clamp(16px, 2.5vw, 22px);
  width: 90%;
  max-width: 500px;
  font-weight: bold;
}

.option {
  display: block;
  margin: 10px auto;
  padding: clamp(10px, 2.5vw, 18px);
  width: 90%;
  max-width: 500px;
  background: rgba(255,255,255,0.2);
  border: 2px solid rgba(255,255,255,0.5);
  border-radius: 6px;
  cursor: pointer;
  color: #000; /* النص باللون الأسود */
  font-size: clamp(16px, 2.5vw, 22px);
  font-weight: bold;
}

.option:hover {
  background: rgba(255,255,255,0.3);
}

.question {
  font-size: clamp(22px, 5vw, 40px); /* أكبر ومتجاوب */
  font-weight: bold;
  color: #000; /* السؤال باللون الأسود */
  margin: 20px auto;
  max-width: 90%;
}

.result {
  font-size: clamp(18px, 3vw, 26px);
  margin-top: 20px;
  color: #fff;
  font-weight: bold;
}

.correct {
  color: #008000; /* أخضر غامق */
  font-weight: bold;
  font-size: clamp(20px, 4vw, 32px); /* أكبر ومتجاوب */
}

.wrong {
  color: #b30000; /* أحمر غامق */
  font-weight: bold;
  font-size: clamp(20px, 4vw, 32px); /* أكبر ومتجاوب */
}

#models {
